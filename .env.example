# =============================================================================
# News Trend Analyzer - Environment Template
# =============================================================================
# Copy this file to .env and fill in local secrets. Never commit real keys.

# Required for AI summaries and daily brief generation.
GEMINI_API_KEY=

# Optional. Defaults to local SQLite at news_analyzer.db.
# For Supabase, paste the Session Pooler URI from Project > Connect.
DATABASE_URL=

# Optional. Defaults to gemini-3.1-flash-lite when omitted.
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional. Reserved for future GitHub API usage; current GitHub Trending
# ingestion scrapes the public trending page and does not require this token.
GITHUB_TOKEN=
